{
  "name": "yield",
  "version": "0.1.0",
  "private": true,
  "description": "Yield — a free AI coder. Chat turns prompts into apps, with manual editing, live preview, NVIDIA-hosted models, and a jailbreak guard. Runs on Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create yield-db",
    "db:init": "wrangler d1 execute yield-db --file=./schema.sql --remote",
    "db:init:local": "wrangler d1 execute yield-db --file=./schema.sql --local",
    "kv:create": "wrangler kv namespace create KV",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.20.0"
  }
}
