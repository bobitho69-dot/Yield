# Yield AI server config — copy to `.env` and edit, then `./serve.sh` reads it.
# This configures the model server that runs on YOUR GPU. None of these are sent
# anywhere except your own machine.

# --- Which open-weights model to serve ----------------------------------------
# The default is a strong, real, open coding model. Swap it for any newer/bigger
# open coder as they ship (see the README's model table). Must be a Hugging Face id
# or a local path.
YIELD_AI_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# The name the server advertises this model as. This MUST match YIELD_AI_MODEL_ID in
# your Yield Worker config (wrangler.toml). Keep it "yield-ai" and everything lines up.
YIELD_AI_SERVED_NAME=yield-ai

# --- Network ------------------------------------------------------------------
YIELD_AI_HOST=0.0.0.0
YIELD_AI_PORT=8000

# A shared secret clients must send as a Bearer token. STRONGLY recommended if the
# server is reachable from the internet. Generate one: `openssl rand -hex 32`.
# Put the SAME value in your Yield Worker as the YIELD_AI_API_KEY secret.
# Leave blank for no auth (only safe on a private network / SSH tunnel).
YIELD_AI_API_KEY=

# --- Capacity / quality knobs -------------------------------------------------
# Max context window (prompt + output tokens). 32768 is a good default for app builds.
# Lower it if you hit out-of-memory; raise it (up to the model's max) if you have room.
YIELD_AI_MAX_LEN=32768

# Number of GPUs to shard the model across (tensor parallelism). 1 for a single GPU;
# set to 2/4/8 for a multi-GPU box serving a bigger model.
YIELD_AI_GPUS=1

# Fraction of each GPU's memory vLLM may use (0.0–1.0). 0.90 is a safe default.
YIELD_AI_GPU_MEM=0.90

# Optional quantization to fit a bigger model on a smaller GPU: awq | gptq | fp8 | (blank).
# Requires a matching pre-quantized checkpoint (e.g. an "...-AWQ" model id). Blank = none.
YIELD_AI_QUANT=

# Extra raw flags passed straight to `vllm serve` (advanced). Example:
#   YIELD_AI_EXTRA="--enable-prefix-caching --max-num-seqs 64"
YIELD_AI_EXTRA=
