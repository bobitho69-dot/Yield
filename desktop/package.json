{
  "name": "yield-desktop",
  "productName": "Yield",
  "version": "1.0.0",
  "description": "Yield for desktop — the agentic coder (Yield Code), Yield Chat, and the app builder in one app.",
  "author": "Penusila Digital Solutions LLC",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis",
    "dist:all": "electron-builder -mw"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.penusila.yield",
    "productName": "Yield",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Yield ${version}"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Yield-setup-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
