# Copy to `.dev.vars` for local `wrangler dev`, or set in production with
#   wrangler secret put <NAME>
# NEVER commit the real .dev.vars file (it is gitignored).

# --- NVIDIA (required) ---------------------------------------------------------
# Free key from https://build.nvidia.com -> open any model -> "Get API Key".
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Session signing (required) ------------------------------------------------
# Any long random string. Generate: `openssl rand -hex 32`
SESSION_SECRET=replace-with-a-long-random-string

# --- OAuth (required for login) ------------------------------------------------
# GitHub: https://github.com/settings/developers  (callback: <APP_URL>/api/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials (callback: <APP_URL>/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (required for the $20/mo plan) -------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
