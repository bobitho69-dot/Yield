# Copy to `.dev.vars` for local `wrangler dev`, or set in production with
#   wrangler secret put <NAME>
# NEVER commit the real .dev.vars file (it is gitignored).

# --- NVIDIA shared key (required) ----------------------------------------------
# Free key from https://build.nvidia.com -> open any model -> "Get API Key".
# Every AI falls back to this key if its own key (below) is unset.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Per-AI keys (each AI is its own API) --------------------------------------
# Set these to use separate keys/accounts/endpoints per AI. Leave any blank to
# fall back to NVIDIA_API_KEY above. One row per AI you gave:
KIMI_API_KEY=             # Kimi K2.6
MINIMAX_API_KEY=          # MiniMax M3
DEEPSEEK_FLASH_API_KEY=   # DeepSeek V4 Flash
STEP_API_KEY=             # Step 3.7 Flash
DEEPSEEK_PRO_API_KEY=     # DeepSeek V4 Pro
GLM_API_KEY=              # GLM 5.1
GPTOSS_API_KEY=           # gpt-oss-20b (Auto router)
NEMOGUARD_API_KEY=        # NeMoGuard JailbreakDetect (prompt guard)

# --- Session signing (required) ------------------------------------------------
# Any long random string. Generate: `openssl rand -hex 32`
SESSION_SECRET=replace-with-a-long-random-string

# --- OAuth (required for login) ------------------------------------------------
# GitHub: https://github.com/settings/developers  (callback: <APP_URL>/api/auth/github/callback)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google: https://console.cloud.google.com/apis/credentials (callback: <APP_URL>/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (required for the $20/mo plan) -------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- AI image generation (optional) --------------------------------------------
# Endpoint URL goes in wrangler.toml [vars] (IMAGE_API_URL); the key is a secret.
# Leave blank to reuse NVIDIA_API_KEY for NVIDIA FLUX image generation.
IMAGE_API_KEY=
